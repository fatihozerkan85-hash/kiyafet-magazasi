PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# iyzico Test Anahtarları (Sandbox)
IYZICO_API_KEY=sandbox-test
IYZICO_SECRET_KEY=sandbox-test
